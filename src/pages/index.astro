---
import '../styles/global.css'
---

<!doctype html>
<html lang='ja' class='scroll-smooth'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Portfolio — HRTK92</title>
    <link rel='preconnect' href='https://fonts.googleapis.com' />
    <link rel='preconnect' href='https://fonts.gstatic.com' crossorigin />
    <link
      href='https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Mono:wght@400;500&family=DM+Sans:wght@300;400;500&display=swap'
      rel='stylesheet'
    />
  </head>
  <body class='font-sans font-light text-ink bg-bg leading-relaxed'>
    <!-- NAV -->
    <nav
      class='fixed top-0 left-0 right-0 z-50 flex items-center justify-between px-12 py-5 bg-bg/85 backdrop-blur-md border-b border-border'
    >
      <a href='#' class='font-mono text-xs tracking-widest text-accent no-underline'>Takuho.dev</a>
      <ul class='flex gap-10 list-none'>
        <li>
          <a
            href='#about'
            class='text-xs tracking-widest uppercase text-muted hover:text-ink transition-colors no-underline'
            >About</a
          >
        </li>
        <li>
          <a
            href='#skills'
            class='text-xs tracking-widest uppercase text-muted hover:text-ink transition-colors no-underline'
            >Skills</a
          >
        </li>
        <li>
          <a
            href='#works'
            class='text-xs tracking-widest uppercase text-muted hover:text-ink transition-colors no-underline'
            >Works</a
          >
        </li>
        <li>
          <a
            href='#contact'
            class='text-xs tracking-widest uppercase text-muted hover:text-ink transition-colors no-underline'
            >Contact</a
          >
        </li>
      </ul>
    </nav>

    <!-- HERO -->
    <section
      id='hero'
      class='min-h-screen flex flex-col justify-end px-12 pt-32 pb-20 border-b border-border relative'
    >
      <p class='anim-1 font-mono text-xs tracking-widest text-accent uppercase mb-6'>
        University Student &amp; Developer
      </p>
      <h1 class='anim-2 font-serif text-8xl leading-none tracking-tight max-w-xl'>
        I'm <em class='text-accent not-italic'>Takuho</em>.
      </h1>
      <p class='anim-3 mt-10 text-base text-muted max-w-xs'>OSS lover. Learner. Builder.</p>
      <div
        class='anim-4 absolute bottom-10 right-12 font-mono text-xs tracking-widest text-muted flex flex-col items-center gap-3'
        style='writing-mode:vertical-rl'
      >
        <span class='block w-px h-12 bg-border'></span>Scroll
      </div>
    </section>

    <!-- ABOUT -->
    <section id='about' class='px-12 py-28 border-b border-border'>
      <p
        class='reveal font-mono text-xs tracking-widest text-accent uppercase mb-14 flex items-center gap-4'
      >
        About <span class='block h-px w-14 bg-accent opacity-40'></span>
      </p>
      <div class='grid grid-cols-2 gap-20 items-start'>
        <div class='reveal'>
          <h2 class='font-serif text-5xl leading-tight tracking-tight'>
            A bit<br />about me.
          </h2>
          <div class='mt-10 flex flex-col gap-3'>
            <div class='flex gap-6 text-sm'>
              <span class='font-mono text-muted tracking-wide w-20'>Name</span><span>Takuho</span>
            </div>
            <div class='flex gap-6 text-sm'>
              <span class='font-mono text-muted tracking-wide w-20'>Status</span><span
                >University Student</span
              >
            </div>
            <div class='flex gap-6 text-sm'>
              <span class='font-mono text-muted tracking-wide w-20'>Location</span><span
                >Saitama, Japan</span
              >
            </div>
          </div>
        </div>
        <div class='reveal text-sm text-muted leading-loose space-y-5'>
          <p>
            中学生でプログラミングに出会い、Webアプリやツール開発にはまっています。コードを書くことで、アイデアを形にできる楽しさを感じています。
          </p>
          <p>
            TypeScript や Python を中心に学んでいます。セルフホストや、Web
            サービスの仕組みを理解するのが好きです。
          </p>
          <p>
            将来はソフトウェアエンジニアとして、使う人の役に立つプロダクトを作りたいと考えています。
          </p>
        </div>
      </div>
    </section>

    <!-- SKILLS -->
    <section id='skills' class='px-12 py-28 border-b border-border'>
      <p
        class='reveal font-mono text-xs tracking-widest text-accent uppercase mb-14 flex items-center gap-4'
      >
        Skills <span class='block h-px w-14 bg-accent opacity-40'></span>
      </p>
      <div class='grid grid-cols-3 gap-px bg-border border border-border'>
        <div class='skill-item reveal bg-bg hover:bg-white transition-colors p-7'>
          <div class='font-mono text-sm mb-2'>Python</div>
          <div class='h-0.5 bg-border rounded-full overflow-hidden'>
            <div class='skill-fill h-full bg-accent rounded-full' style='width:65%'></div>
          </div>
          <div class='mt-2 text-xs text-muted tracking-wide'>Intermediate</div>
        </div><div class='skill-item reveal bg-bg hover:bg-white transition-colors p-7'>
          <div class='font-mono text-sm mb-2'>TypeScript</div>
          <div class='h-0.5 bg-border rounded-full overflow-hidden'>
            <div class='skill-fill h-full bg-accent rounded-full' style='width:65%'></div>
          </div>
          <div class='mt-2 text-xs text-muted tracking-wide'>Intermediate</div>
        </div>
        <div class='skill-item reveal bg-bg hover:bg-white transition-colors p-7'>
          <div class='font-mono text-sm mb-2'>React</div>
          <div class='h-0.5 bg-border rounded-full overflow-hidden'>
            <div class='skill-fill h-full bg-accent rounded-full' style='width:65%'></div>
          </div>
          <div class='mt-2 text-xs text-muted tracking-wide'>Intermediate</div>
        </div>
        <div class='skill-item reveal bg-bg hover:bg-white transition-colors p-7'>
          <div class='font-mono text-sm mb-2'>Git / GitHub</div>
          <div class='h-0.5 bg-border rounded-full overflow-hidden'>
            <div class='skill-fill h-full bg-accent rounded-full' style='width:65%'></div>
          </div>
          <div class='mt-2 text-xs text-muted tracking-wide'>Intermediate</div>
        </div>
        <div class='skill-item reveal bg-bg hover:bg-white transition-colors p-7'>
          <div class='font-mono text-sm mb-2'>Linux / CLI</div>
          <div class='h-0.5 bg-border rounded-full overflow-hidden'>
            <div class='skill-fill h-full bg-accent rounded-full' style='width:65%'></div>
          </div>
          <div class='mt-2 text-xs text-muted tracking-wide'>Intermediate</div>
        </div>
        <div class='skill-item reveal bg-bg hover:bg-white transition-colors p-7'>
          <div class='font-mono text-sm mb-2'>Go</div>
          <div class='h-0.5 bg-border rounded-full overflow-hidden'>
            <div class='skill-fill h-full bg-accent rounded-full' style='width:40%'></div>
          </div>
          <div class='mt-2 text-xs text-muted tracking-wide'>Learning</div>
        </div>
      </div>
    </section>

    <!-- WORKS -->
    <section id='works' class='px-12 py-28 border-b border-border'>
      <p
        class='reveal font-mono text-xs tracking-widest text-accent uppercase mb-14 flex items-center gap-4'
      >
        Works <span class='block h-px w-14 bg-accent opacity-40'></span>
      </p>
      <div class='grid grid-cols-3 gap-6'>
        <div
          class='reveal border border-border bg-white p-8 hover:-translate-y-1 hover:shadow-xl transition-all duration-300'
        >
          <div class='font-mono text-xs tracking-widest text-accent uppercase mb-4'>Library</div>
          <h3 class='font-serif text-2xl leading-snug mb-3'>py-mcws</h3>
          <p class='text-sm text-muted leading-relaxed mb-6'>
            Minecraft の WebSocket サーバーを Python で操作するツール。
          </p>
          <div class='flex flex-wrap gap-2'>
            <span class='font-mono text-xs px-2.5 py-1 border border-border text-muted'>Python</span
            >
          </div>
          <a
            href='https://github.com/HRTK92/py-mcws'
            target='_blank'
            class='inline-block mt-6 text-xs tracking-widest uppercase border-b border-ink pb-px hover:text-accent hover:border-accent transition-colors no-underline'
            >GitHub →</a
          >
        </div>
        <div
          class='reveal border border-border bg-white p-8 hover:-translate-y-1 hover:shadow-xl transition-all duration-300'
        >
          <div class='font-mono text-xs tracking-widest text-accent uppercase mb-4'>Web App</div>
          <h3 class='font-serif text-2xl leading-snug mb-3'>弓道部支援アプリ（仮）</h3>
          <p class='text-sm text-muted leading-relaxed mb-6'>
            出身高校の弓道部で実際に使用されている部活支援アプリ。練習記録や部員管理を効率化。
          </p>
          <div class='flex flex-wrap gap-2'>
            <span class='font-mono text-xs px-2.5 py-1 border border-border text-muted'
              >Next.js</span
            >
            <span class='font-mono text-xs px-2.5 py-1 border border-border text-muted'
              >TypeScript</span
            >
            <span class='font-mono text-xs px-2.5 py-1 border border-border text-muted'
              >Cloudflare</span
            >
          </div>
        </div>
        <div
          class='reveal border border-border bg-white p-8 hover:-translate-y-1 hover:shadow-xl transition-all duration-300'
        >
          <div class='font-mono text-xs tracking-widest text-accent uppercase mb-4'>
            Coming Soon
          </div>
          <h3 class='font-serif text-2xl leading-snug mb-3'>Next Project</h3>
          <p class='text-sm text-muted leading-relaxed mb-6'>...</p>
          <div class='flex flex-wrap gap-2'>
            <span class='font-mono text-xs px-2.5 py-1 border border-border text-muted'>WIP</span>
          </div>
        </div>
      </div>
    </section>

    <!-- CONTACT -->
    <section id='contact' class='px-12 py-28 flex flex-col items-center text-center gap-8'>
      <p
        class='reveal self-start font-mono text-xs tracking-widest text-accent uppercase flex items-center gap-4'
      >
        Contact <span class='block h-px w-14 bg-accent opacity-40'></span>
      </p>
      <h2 class='reveal font-serif text-7xl leading-tight tracking-tight'>
        一緒に何か<br /><em class='text-accent not-italic'>作りませんか。</em>
      </h2>
      <p class='reveal text-base text-muted max-w-xs'>お気軽にご連絡ください。</p>
      <div class='reveal flex gap-8 mt-4 flex-wrap justify-center'>
        <a
          href='mailto:hrtk92@proton.me'
          class='flex items-center gap-2 font-mono text-sm tracking-widest text-ink hover:text-accent transition-colors no-underline'
        >
          <svg
            class='w-4 h-4'
            fill='none'
            stroke='currentColor'
            stroke-width='1.8'
            viewBox='0 0 24 24'
            ><rect x='2' y='4' width='20' height='16' rx='2'></rect><polyline
              points='2,4 12,13 22,4'></polyline></svg
          >
          hrtk92@proton.me
        </a>
        <a
          href='https://github.com/HRTK92'
          target='_blank'
          class='flex items-center gap-2 font-mono text-sm tracking-widest text-ink hover:text-accent transition-colors no-underline'
        >
          <svg
            class='w-4 h-4'
            fill='none'
            stroke='currentColor'
            stroke-width='1.8'
            viewBox='0 0 24 24'
            ><path
              d='M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22'
            ></path></svg
          >
          GitHub
        </a>
        <a
          href='https://twitter.com/'
          target='_blank'
          class='flex items-center gap-2 font-mono text-sm tracking-widest text-ink hover:text-accent transition-colors no-underline'
        >
          <svg
            class='w-4 h-4'
            fill='none'
            stroke='currentColor'
            stroke-width='1.8'
            viewBox='0 0 24 24'
            ><path
              d='M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z'
            ></path></svg
          >
          Twitter / X
        </a>
      </div>
    </section>

    <!-- FOOTER -->
    <footer
      class='px-12 py-6 flex justify-between items-center border-t border-border font-mono text-xs text-muted tracking-wide'
    >
      <span>© 2026 HRTK92</span>
      <span>assisted by Claude</span>
    </footer>

    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) entry.target.classList.add('visible')
          })
        },
        { threshold: 0.12 },
      )
      document.querySelectorAll('.reveal').forEach((el) => observer.observe(el))
    </script>
  </body>
</html>
